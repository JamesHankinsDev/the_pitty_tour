# Firebase Configuration
# Copy this file to .env.local and fill in your values from Firebase Console
# Project Settings > General > Your apps > Firebase SDK snippet > Config

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GHIN Integration
# Server-side handicap lookups via /api/ghin/lookup
# Use any valid GHIN account (email or GHIN number + password) as a service account
GHIN_USERNAME=your_ghin_email_or_number
GHIN_PASSWORD=your_ghin_password
GHIN_GOOGLE_API_KEY=your_ghin_google_api_key

# GolfCourseAPI (external course database)
# Get your free API key at https://golfcourseapi.com
GOLF_COURSE_API_KEY=your_golf_course_api_key

# Firebase Cloud Messaging (Push Notifications)
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key

# Firebase Admin SDK (server-side only, for sending push notifications)
# Get from: Firebase Console > Project Settings > Service accounts > Generate new private key
# Paste the entire JSON file contents as a single line
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
