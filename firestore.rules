rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────

    function authed() {
      return request.auth != null;
    }

    function isMe(uid) {
      return authed() && request.auth.uid == uid;
    }

    function admin() {
      return authed()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function hasRole(role) {
      return authed()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && role in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }

    // ─── Users ────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if authed();
      allow create: if isMe(uid);
      allow update: if isMe(uid) || admin();
      allow delete: if false;

      // Handicap history subcollection
      match /handicapHistory/{entryId} {
        allow read: if authed();
        allow create: if isMe(uid);
        allow update, delete: if false;
      }
    }

    // ─── Seasons ─────────────────────────────────────────────────────────
    match /seasons/{seasonId} {
      allow read: if authed();
      allow write: if admin();
    }

    // ─── Registrations ───────────────────────────────────────────────────
    match /registrations/{regId} {
      allow read: if authed();
      allow write: if admin();
    }

    // ─── Rounds ──────────────────────────────────────────────────────────
    match /rounds/{roundId} {
      allow read: if authed();

      // Create: must be own round, empty attestations, not selected
      // 9-hole rounds are auto-valid; 18-hole rounds start invalid
      allow create: if authed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.attestations.size() == 0
        && request.resource.data.selectedForScoring == false
        && (
          (request.resource.data.holeCount == 18 && request.resource.data.isValid == false)
          || (request.resource.data.holeCount == 9 && request.resource.data.isValid == true)
        );

      // Update: admin can do anything; otherwise two cases:
      allow update: if admin()
        // Case 1: Attestation — another player adds attestation
        || (authed()
          && resource.data.uid != request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.grossScore == resource.data.grossScore
          && request.resource.data.netScore == resource.data.netScore
          && request.resource.data.courseName == resource.data.courseName
          && request.resource.data.slopeRating == resource.data.slopeRating
          && request.resource.data.courseRating == resource.data.courseRating
          && request.resource.data.attestations.size() == resource.data.attestations.size() + 1)
        // Case 2: Round selection — owner toggles selectedForScoring
        || (authed()
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.grossScore == resource.data.grossScore
          && request.resource.data.netScore == resource.data.netScore
          && request.resource.data.courseName == resource.data.courseName
          && request.resource.data.slopeRating == resource.data.slopeRating
          && request.resource.data.courseRating == resource.data.courseRating
          && request.resource.data.isValid == resource.data.isValid
          && request.resource.data.attestations.size() == resource.data.attestations.size());

      allow delete: if admin();
    }

    // ─── Points ──────────────────────────────────────────────────────────
    match /points/{pointId} {
      allow read: if authed();
      allow write: if admin();
    }

    // ─── Push Tokens ─────────────────────────────────────────────────────
    match /pushTokens/{tokenId} {
      allow read: if authed();
      allow create, update: if authed();
      allow delete: if authed();
    }

    // ─── Notifications ───────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if authed();
      allow create: if authed();
      allow update: if admin();
      allow delete: if authed();
    }

    // ─── Notification Read Cursors ───────────────────────────────────────
    match /notificationReads/{uid} {
      allow read, write: if isMe(uid);
    }

    // ─── Payouts ─────────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if authed();
      allow write: if admin();
    }

    // ─── Month Closes ───────────────────────────────────────────────────
    match /monthCloses/{closeId} {
      allow read: if authed();
      allow write: if admin();
    }

    // ─── Courses ──────────────────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if authed();
      allow create: if authed();
      allow update: if authed();
      allow delete: if admin();

      // Course reviews subcollection
      match /reviews/{reviewId} {
        allow read: if authed();
        allow create: if authed()
          && request.resource.data.uid == request.auth.uid;
        allow delete: if authed();
        allow update: if false;
      }
    }

    // ─── Cached Courses (GolfCourseAPI imports) ──────────────────────────
    match /cachedCourses/{courseId} {
      allow read: if authed();
      // Any authed user can create/update (cache-fill on search)
      allow create, update: if authed();
      allow delete: if admin();
    }

    // ─── Exhibition Sessions ──────────────────────────────────────────────
    match /exhibitionSessions/{sessionId} {
      // Lobby sessions are readable by anyone authed (for join flow)
      // Active/completed sessions readable by anyone authed (players + spectators)
      allow read: if authed();

      // Any authed user can create (they become host)
      allow create: if authed()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'lobby';

      // Only host can update the session document
      allow update: if authed() && resource.data.hostId == request.auth.uid;

      // Only host can delete (pre-completion)
      allow delete: if authed() && resource.data.hostId == request.auth.uid;

      // Players subcollection — doc ID = userId
      match /players/{playerUid} {
        allow read: if authed();
        // A user can only write their own player doc
        allow create, update: if isMe(playerUid);
        // Host can update any player (for team assignments, kicks, etc.)
        allow update: if authed()
          && get(/databases/$(database)/documents/exhibitionSessions/$(sessionId)).data.hostId == request.auth.uid;
        allow delete: if isMe(playerUid)
          || (authed() && get(/databases/$(database)/documents/exhibitionSessions/$(sessionId)).data.hostId == request.auth.uid);
      }

      // Card log subcollection — any player in the session can write
      match /cardLog/{logId} {
        allow read: if authed();
        allow create: if authed();
        // Host can override entries
        allow update: if authed()
          && get(/databases/$(database)/documents/exhibitionSessions/$(sessionId)).data.hostId == request.auth.uid;
        allow delete: if false;
      }
    }

    // ─── Scheduled Rounds ──────────────────────────────────────────────────
    match /scheduledRounds/{roundId} {
      allow read: if authed();
      // Any authed user can create a scheduled round (they become host)
      allow create: if authed()
        && request.resource.data.hostUid == request.auth.uid;
      // Any authed user can update (join/leave adds/removes uid from players array)
      allow update: if authed();
      // Only the host or admin can delete
      allow delete: if admin()
        || (authed() && resource.data.hostUid == request.auth.uid);
    }

    // ─── Announcements ────────────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if authed();
      // Only Admin, Commissioner, or Secretary can manage announcements
      allow create: if admin() || hasRole('commissioner') || hasRole('secretary');
      allow update: if admin() || hasRole('commissioner') || hasRole('secretary');
      allow delete: if admin();
    }

    // ─── Current Officers ─────────────────────────────────────────────────
    match /currentOfficers/{officerId} {
      allow read: if authed();
      allow write: if admin();
    }

    // ─── Flagged Rounds ──────────────────────────────────────────────────
    match /flaggedRounds/{flagId} {
      allow read: if authed();
      allow create: if authed();
      allow delete: if admin();
      allow update: if false;
    }

    // ─── Polls ───────────────────────────────────────────────────────────
    match /polls/{pollId} {
      allow read: if authed();
      allow create, update, delete: if admin();

      // Options subcollection
      match /options/{optionId} {
        allow read: if authed();
        // Members can add options only if parent poll allows it
        allow create: if authed()
          && get(/databases/$(database)/documents/polls/$(pollId)).data.allowMemberOptions == true;
        allow update, delete: if admin();
      }

      // Candidates subcollection (for elections)
      match /candidates/{candidateId} {
        allow read: if authed();
        allow create: if authed();
        allow update: if authed();
        allow delete: if admin();
      }

      // Votes subcollection — doc ID must be the voter's uid
      match /votes/{voterId} {
        allow read: if authed();
        allow create, update: if isMe(voterId);
        allow delete: if false;
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if authed();
        allow create: if authed();
        allow delete: if authed();
        allow update: if false;
      }
    }

    // ─── Messages ────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if authed();
      allow create: if authed()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if authed();
      // Only the reactions map may change; all other fields must be unchanged.
      allow update: if authed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
    }

    // ─── Feedback ────────────────────────────────────────────────────────
    match /feedback/{feedbackId} {
      // Users can read their own; admin can read all
      allow read: if authed()
        && (resource.data.uid == request.auth.uid || admin());
      // List requires a where('uid', '==', me) filter unless admin
      allow list: if authed();

      // Create: must be self-authored
      allow create: if authed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'new'
        && request.resource.data.adminResponse == ''
        && request.resource.data.respondedAt == null;

      // Update: admin can update anything; owner can edit while still 'new'
      allow update: if admin()
        || (authed()
          && resource.data.uid == request.auth.uid
          && resource.data.status == 'new'
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.status == 'new'
          && request.resource.data.adminResponse == ''
          && request.resource.data.respondedAt == null);

      // Delete: admin or owner (while still 'new')
      allow delete: if admin()
        || (authed()
          && resource.data.uid == request.auth.uid
          && resource.data.status == 'new');
    }

    // ─── Invites ─────────────────────────────────────────────────────────
    match /invites/{token} {
      // Anyone can read a single invite by token (the token IS the secret)
      allow get: if true;
      // Listing requires auth (recovery query) or admin
      allow list: if authed();

      // Only admins create invites
      allow create: if admin()
        && request.resource.data.status == 'pending'
        && request.resource.data.usedAt == null
        && request.resource.data.usedByUid == null;

      // Claim: authenticated user marks pending invite as used
      // Admin: can update anything
      allow update: if admin()
        || (authed()
          && resource.data.status == 'pending'
          && request.resource.data.status == 'used'
          && request.resource.data.usedByUid == request.auth.uid);

      allow delete: if false;
    }
  }
}
